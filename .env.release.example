# Copy to .env.release (gitignored) and fill from 1Password.
# Used by scripts/release-local.sh — mirrors the GitHub Actions secrets.

# --- Apple notarization (signing identity comes from your login keychain) ---
APPLE_ID="you@example.com"
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password, not your Apple ID password
APPLE_TEAM_ID="ABC123DE45"
# Optional: pin a specific identity by SHA-1 (run `security find-identity -v -p codesigning`).
# Required if you have more than one "Developer ID Application" identity in your keychains.
# APPLE_SIGNING_IDENTITY="ABCDEF0123456789ABCDEF0123456789ABCDEF01"

# --- Tauri updater signing key ---
# Either the raw key contents (multiline) or an absolute path to ~/.tauri/argus.key.
TAURI_SIGNING_PRIVATE_KEY="/Users/you/.tauri/argus.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="your-updater-key-passphrase"

# --- AWS (release hosting via S3 + CloudFront) ---
# Role ARN emitted by ArgusReleasesStack CfnOutput "PublishRoleArn".
# The CI workflow assumes this role via GitHub OIDC — no long-lived keys needed.
AWS_RELEASE_ROLE_ARN="arn:aws:iam::123456789012:role/ArgusReleasesPublishRole"
# AWS region where ArgusReleasesStack is deployed (e.g. us-east-1).
AWS_REGION="us-east-1"
# S3 bucket name emitted by ArgusReleasesStack CfnOutput "BucketName".
RELEASE_S3_BUCKET="argus-releases-bucket-xxxx"
# CloudFront distribution ID emitted by ArgusReleasesStack CfnOutput "DistributionId".
RELEASE_CLOUDFRONT_DISTRIBUTION_ID="EXXXXXXXXXXXXXXXXX"
# CloudFront public base URL (no trailing slash) emitted by ArgusReleasesStack CfnOutput "PublicBaseUrl".
# Used by build-manifest.mjs and build-download-manifest.mjs to construct artifact URLs.
PUBLIC_URL_BASE="https://xxxxxxxxxxxx.cloudfront.net"
