{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Argus",
  "windows": ["manager", "workspace", "connection-form", "feedback"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:image:default",
    "core:menu:default",
    "core:resources:default",
    "core:tray:default",
    "core:path:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DESKTOP/*" },
        { "path": "$HOME/*" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DESKTOP/*" },
        { "path": "$HOME/*" }
      ]
    }
  ]
}
