{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Argus",
  "version": "0.6.2",
  "identifier": "com.argus.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "manager",
        "title": "Argus",
        "width": 760,
        "height": 600,
        "minWidth": 520,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Inspect and edit data across multiple sources",
    "longDescription": "Argus is a desktop tool for inspecting and editing data across PostgreSQL, MySQL/MariaDB, Microsoft SQL Server, DynamoDB, Amazon CloudWatch Logs, and Amazon Athena."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.argusdb.app/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDRTI4MDk3MjBCQjRDRjEKUldUeFRMc2dsNERpUE9HU0V3cUxhQmllWk1mWFkxRktuT0hnQXd0eFljdzZkK3hJOXpuNGZqUEMK"
    }
  }
}
