{
  "name": "argus-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter argus dev",
    "build": "pnpm --filter argus build",
    "preview": "pnpm --filter argus preview",
    "tauri:dev": "pnpm --filter argus tauri:dev",
    "tauri:build": "pnpm --filter argus tauri:build",
    "typecheck": "pnpm --filter argus typecheck",
    "lint": "pnpm --filter argus lint",
    "format": "pnpm --filter argus format",
    "test": "pnpm --filter argus test",
    "test:run": "pnpm --filter argus test:run",
    "infra": "pnpm --filter infra",
    "infra:build": "pnpm --filter infra build",
    "infra:synth": "pnpm --filter infra cdk synth"
  }
}
